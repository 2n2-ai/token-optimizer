#!/usr/bin/env python3
"""Entrypoint shim for token-optimizer.

Symlink or alias this to your PATH, or run `python3 src/token_optimizer.py`
directly. We import-by-path so the CLI stays pip-free and stdlib-only.
"""
import os
import runpy
import sys

HERE = os.path.dirname(os.path.abspath(__file__))
TARGET = os.path.normpath(os.path.join(HERE, "..", "src", "token_optimizer.py"))
sys.argv[0] = "token-optimizer"
runpy.run_path(TARGET, run_name="__main__")
